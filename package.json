{
  "name": "lygodactylus",
  "version": "6.0.1",
  "description": "Lygodactylus — open-source local AI agent desktop app for Windows, macOS & Linux with Ollama/vLLM support, MCP tools, Skills, and sandbox isolation",
  "keywords": [
    "ai-agent",
    "electron",
    "desktop-app",
    "mcp",
    "sandbox",
    "open-source",
    "ai-coding",
    "ai-tools",
    "ollama",
    "vllm",
    "local-llm",
    "skills"
  ],
  "homepage": "https://github.com/emilien-etadam/lygodactylus",
  "repository": {
    "type": "git",
    "url": "https://github.com/emilien-etadam/lygodactylus.git"
  },
  "bugs": {
    "url": "https://github.com/emilien-etadam/lygodactylus/issues"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "npm run download:node && npm run build:wsl-agent && npm run build:lima-agent && npm run build:mcp && vite",
    "dev:with-python": "npm run download:node && npm run prepare:python && npm run build:wsl-agent && npm run build:lima-agent && npm run build:mcp && vite",
    "build": "npm run build:wsl-agent && npm run build:lima-agent && npm run build:mcp && tsc && vite build && npm run generate:icons && node scripts/pre-build-check.js && electron-builder",
    "build:win": "node scripts/build-windows.js",
    "build:linux": "node scripts/build-linux.js",
    "build:wsl-agent": "tsc -p src/main/sandbox/wsl-agent/tsconfig.json",
    "build:lima-agent": "tsc -p src/main/sandbox/lima-agent/tsconfig.json",
    "build:mcp": "node scripts/bundle-mcp.js",
    "download:node": "node scripts/download-node.mjs",
    "postinstall": "patch-package && node scripts/download-node.mjs && npm run rebuild",
    "prepare:gui-tools": "node scripts/prepare-gui-tools.js",
    "prepare:python": "node scripts/prepare-python.js",
    "prepare:python:all": "node scripts/prepare-python.js --all",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:runtime": "node scripts/audit-runtime.mjs",
    "rebuild": "node -e \"const {execSync}=require('node:child_process'); const v=require('electron/package.json').version; execSync('npm rebuild better-sqlite3 --runtime=electron --target='+v+' --disturl=https://electronjs.org/headers',{stdio:'inherit'})\"",
    "typecheck": "tsc --noEmit",
    "generate:icons": "node scripts/generate-app-icons.js",
    "pre-build-check": "node scripts/pre-build-check.js",
    "clean": "rimraf dist dist-electron dist-mcp dist-wsl-agent dist-lima-agent .bundle-resources release"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^4.0.1",
    "dotenv": "^17.4.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "glob": "^13.0.6",
    "highlight.js": "^11.11.1",
    "i18next": "^25.10.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "katex": "^0.17.0",
    "lucide-react": "^1.23.0",
    "patch-package": "8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.6.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "typebox": "^1.3.4",
    "uuid": "^13.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@eslint/js": "^9.0.0",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "png-to-ico": "2.1.8",
    "png2icons": "2.0.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "sharp": "0.34.5",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "axios": "^1.18.1",
    "fast-xml-parser": "^5.5.6",
    "tar": "^7.5.11"
  },
  "author": "Lygodactylus",
  "license": "MIT"
}
