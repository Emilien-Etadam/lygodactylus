{
  "manifest_version": 3,
  "name": "Lygodactylus Web",
  "version": "1.1.0",
  "description": "Traduire, résumer, extraire ou modifier des pages web via Lygodactylus (Chat LAN).",
  "browser_specific_settings": {
    "gecko": {
      "id": "lygodactylus-web@emilien-etadam",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Lygodactylus Web",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "64": "icons/icon-64.png"
    }
  },
  "permissions": ["activeTab", "contextMenus", "storage", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/extract.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "sidebar_action": {
    "default_panel": "sidebar/sidebar.html",
    "default_title": "Lygodactylus Web",
    "default_icon": "icons/icon-32.png",
    "open_at_install": false
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
