{
  "manifest_version": 2,
  "name": "Lygodactylus Mail",
  "version": "1.0.0",
  "description": "Résumer, traduire, analyser un e-mail et suggérer/reformuler des réponses via Lygodactylus (Chat LAN).",
  "browser_specific_settings": {
    "gecko": {
      "id": "lygodactylus-mail@emilien-etadam",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "accountsRead",
    "messagesRead",
    "compose",
    "menus",
    "storage",
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "scripts": ["lib/mailPrompts.js", "background.js"]
  },
  "message_display_action": {
    "default_title": "Lygodactylus Mail",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "64": "icons/icon-64.png"
    },
    "type": "menu"
  },
  "compose_action": {
    "default_title": "Lygodactylus Mail",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "64": "icons/icon-64.png"
    },
    "type": "menu"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
